{
  "name": "linkvault",
  "version": "2.1.0",
  "description": "LinkVault — مكتبة الروابط الذكية للويب والآيفون",
  "private": true,
  "scripts": {
    "sync": "npx --no-install cap sync",
    "ios": "npx --no-install cap open ios",
    "android": "npx --no-install cap open android",
    "ios:share-extension": "ruby scripts/add-ios-share-extension.rb",
    "check": "node --check backend/server.js"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  }
}
